# ── Cached data downloads ─────────────────────────────────────────────────────
# These are re-downloaded automatically by the pipeline — safe to exclude.
# Run `python src/pipeline.py --refresh` to re-fetch after cloning.
data/raw/
data/processed/

# ── Pipeline output ───────────────────────────────────────────────────────────
# Generated CSVs and GeoJSONs — re-created by running the pipeline.
output/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Parcel tracker data ───────────────────────────────────────────────────────
# Live on the server only — each environment keeps its own tracker state.
data/tracker.json

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
credentials.json
credentials.yaml        # user logins — NEVER commit this
*.pem                   # SSH key pairs — NEVER commit this

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/settings.local.json

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
