# ── Cached data downloads ─────────────────────────────────────────────────────
# These are re-downloaded automatically by the pipeline — safe to exclude.
# Run `python src/pipeline.py --refresh` to re-fetch after cloning.
data/raw/
data/processed/

# ── Pipeline output ───────────────────────────────────────────────────────────
# Generated CSVs and GeoJSONs — re-created by running the pipeline.
output/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Parcel tracker data ───────────────────────────────────────────────────────
# Live on the server only — each environment keeps its own tracker state.
data/tracker.json

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
credentials.json
# user logins — NEVER commit this
credentials.yaml
# SSH key pairs — NEVER commit this
*.pem

# ── Claude Code local settings ────────────────────────────────────────────────
.claude/settings.local.json

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Utility map PDFs (large binaries; source for water/sewer extraction) ────────
data/utility_pdfs/

# Economic-development review queue.
# The queue + scan-meta ARE tracked so the analyst's curated data deploys to the
# live site (curate locally → push/deploy to publish; don't edit econ-dev on
# live or the next deploy overwrites it). Only the local rolling backup is excluded.
data/econ_dev_queue.bak.json

# Competition-mapping review queue — same pattern as econ-dev above: queue +
# scan-meta are tracked so curated data deploys; only the rolling backup is
# excluded. The geocode cache is excluded too — it's fully re-derivable (free
# Census Geocoder lookups), same reasoning as data/raw/ above.
data/competition_queue.bak.json
data/competition_geocode_cache.json
